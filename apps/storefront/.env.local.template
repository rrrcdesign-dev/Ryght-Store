# Publishable API key for the Medusa backend.
# Create one in Admin → Settings → API Keys → Publishable
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# URL of the Medusa backend API server
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Default region country code to use for the storefront (e.g. au, us, gb)
NEXT_PUBLIC_DEFAULT_REGION=au

# Base URL of the storefront (used for sitemap, OG images, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Stripe publishable key (from https://dashboard.stripe.com/apikeys)
NEXT_PUBLIC_STRIPE_KEY=pk_test_...

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Medusa Cloud S3 settings (optional — only for Medusa Cloud deployments)
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=

# Node environment
NODE_ENV=development
